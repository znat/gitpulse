# Local-dev env vars for the image storage integration test.
#
# Quickest path to populate this file:
#   cp .env.example .env.local
#   vercel env rm BLOB_READ_WRITE_TOKEN development -y || true
#   vercel blob create-store gitpulse-local --access public -y
#   # The Vercel CLI writes BLOB_READ_WRITE_TOKEN into .env.local automatically.
#   # Copy the storeId from the command output into GITPULSE_TEST_STORE_ID below.
#
# CI does not use this file; secrets are injected from GitHub Actions.

BLOB_READ_WRITE_TOKEN=
GITPULSE_TEST_STORE_ID=
